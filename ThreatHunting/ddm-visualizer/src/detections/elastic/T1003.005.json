{
  "name": "Cached Domain Credentials Access via Registry",
  "description": "Detects access to cached domain credentials (DCC2/mscash2) from the SECURITY\\Cache registry key. Covers Mimikatz, cachedump, and Impacket secretsdump approaches.",
  "risk_score": 75,
  "severity": "high",
  "type": "query",
  "language": "kuery",
  "query": "(event.code: \"13\" and winlog.event_data.TargetObject: *SECURITY\\\\Cache*) or (process.command_line: (*lsadump\\:\\:cache* or *cachedump* or *mscash*))",
  "threat": [
    {
      "framework": "MITRE ATT&CK",
      "tactic": { "id": "TA0006", "name": "Credential Access" },
      "technique": [
        {
          "id": "T1003",
          "name": "OS Credential Dumping",
          "subtechnique": [{ "id": "T1003.005", "name": "Cached Domain Credentials" }]
        }
      ]
    }
  ],
  "references": [
    "https://attack.mitre.org/techniques/T1003/005/"
  ],
  "tags": ["Credential Access", "Cached Credentials", "DCC2", "T1003.005"],
  "index": ["winlogbeat-*", "logs-windows.*", "logs-endpoint.events.registry-*"]
}
